<script asp-location="Footer">
    $(function() {
        var $specFilters = $('.js-spec-filter');

        $specFilters.each(function() {
            var $filter = $(this);
            var $list = $filter.find('.js-spec-list');
            var $items = $list.find('.mt-shop-widget-brands-item');
            var $toggle = $filter.find('.js-spec-toggle');
            var visibleCount = 5;

            if (!$toggle.length || !$list.length) return;

            var setToggleState = function() {
                var shouldShowToggle = $items.length > visibleCount;
                if (!shouldShowToggle) {
                    $toggle.hide();
                    $list.removeClass('is-collapsed is-expanded');
                    $items.removeClass('is-hidden-by-toggle');
                    return;
                }

                $toggle.show();
                if ($list.hasClass('is-expanded')) {
                    $toggle.text('Thu gọn');
                    $list.removeClass('is-collapsed');
                    $items.removeClass('is-hidden-by-toggle');
                } else {
                    $toggle.text('Xem thêm');
                    $list.addClass('is-collapsed');
                    $items.each(function(index) {
                        $(this).toggleClass('is-hidden-by-toggle', index >= visibleCount);
                    });
                }
            };

            setToggleState();
            $toggle.off('click.specToggle').on('click.specToggle', function() {
                $list.toggleClass('is-expanded');
                setToggleState();
            });
        });

        var $optionEls = $('[data-option-id]');
        $optionEls.on('change', function () {
            CatalogProducts.getProducts();
        });

        $(CatalogProducts).on('before', function (e) {
            var selectedOptions = $.map($optionEls, function (el) {
                var $optionEl = $(el);
                if ($optionEl.is(':checked')) return $optionEl.data('option-id');
                return null;
            });

            if (selectedOptions && selectedOptions.length > 0) {
                e.payload.urlBuilder
                    .addParameter('specs', selectedOptions.join(','));
            }
        });
    });
</script>
