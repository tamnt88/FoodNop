
@model SpecificationFilterModel
@{
    var totalSpecValues = 0;
    foreach (var attribute in Model.Attributes)
    {
        totalSpecValues += attribute.Values.Count;
    }
}
<!-- categories -->
<div class="mt-shop-widget mb-50 js-spec-filter">
    <h3 class="mt-shop-widget-title mb-20">@T("Filtering.SpecificationFilter")</h3>
    <div class="mt-shop-widget-content">
        <div class="mt-shop-widget-brands js-spec-list is-collapsed">
            @foreach (var attr in Model.Attributes)
            {
                @foreach (var value in attr.Values)
                {
                    <div class="form-check mt-shop-widget-brands-item mb-10">
                        <input class="form-check-input" id="attribute-option-@value.Id" type="checkbox" data-option-id="@value.Id" checked="@value.Selected" />
                        @if (string.IsNullOrEmpty(value.ColorSquaresRgb))
                        {
                            <label class="custom-control-label" for="attribute-option-@value.Id">
                                @value.Name
                            </label>
                        }
                        else
                        {
                            <label for="attribute-option-@value.Id" class="attribute-squares color-squares custom-control-label">
                                <span class="attribute-square" style="background-color: @(value.ColorSquaresRgb);"></span>
                                @value.Name
                            </label>
                        } 
                    </div> 
                } 
            }
        </div>
        @if (totalSpecValues > 5)
        {
            <button type="button" class="mt-shop-widget-more js-spec-toggle">Xem thêm</button>
        }
    </div>
</div>
